[
   {
      "label": "Refresh CMake project [Debug Development]",
      "command": "cmake",
      "args": [
         "-S \"$ZED_WORKTREE_ROOT\"",
         "--preset cmake-build-debug-development",
      ],

      "env": {
         "CC": "clang",
         "CXX": "clang++",
      },

      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "shell": "system",
      "show_summary": true,
      "show_command": true,
      "save": "all",
   },

   {
      "label": "Build [Debug Developement]",
      "command": "cmake",
      "args": [
         "--build \"$ZED_WORKTREE_ROOT/cmake-build-debug-development\"",
         "--parallel",
      ],

      "use_new_terminal": false,
      "allow_concurrent_runs": false,
      "reveal": "always",
      "reveal_target": "dock",
      "hide": "never",
      "shell": "system",
      "show_summary": true,
      "show_command": true,
      "save": "all",
   },
]
